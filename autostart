#!/bin/bash
# KNF Studios GameHub - Openbox Autostart
# Place at: ~/.config/openbox/autostart

# Hide cursor after 3 seconds idle
unclutter -idle 3 &

# Disable screensaver and power management
xset s off
xset s noblank
xset -dpms

# Start HUD overlay (30px bar at very top)
python3 /home/pi/kiosk/hud_overlay.py &

# Start gamepad cursor controller
python3 /home/pi/kiosk/gamepad_cursor.py &

# Watch for new Chromium windows and force correct size/position
python3 /home/pi/kiosk/window_watcher.py &

# Wait for system to settle
sleep 2

# Launch Chromium
# --app mode = no address bar, no tabs, borderless window
# --remote-debugging-port=9222 = CDP for keyboard detection
# --window-position=0,30 = sits below the 30px HUD bar
# --window-size=800,450 = fills rest of 800x480 screen
chromium \
  --app='https://demogamehub4.knfstudios.com/marketplace/' \
  --no-first-run \
  --disable-infobars \
  --noerrdialogs \
  --disable-translate \
  --check-for-update-interval=31536000 \
  --enable-gpu-rasterization \
  --enable-accelerated-video-decode \
  --remote-debugging-port=9222 \
  --window-position=0,30 \
  --window-size=800,450 &
